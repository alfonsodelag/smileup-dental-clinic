---
const items = [
  { title: "Previa cita", detail: "Atención ordenada y sin esperas innecesarias." },
  { title: "Atención personalizada", detail: "Un plan pensado para tu caso, no una fórmula genérica." },
  { title: "Servicios integrales", detail: "Desde prevención hasta estética y rehabilitación dental." },
];
---

<section class="border-y border-borderc bg-shell">
  <div class="container-page grid gap-6 py-8 sm:grid-cols-3">
    {items.map((item) => (
      <div class="flex items-start gap-3">
        <span class="mt-1 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-sage/15 text-sage">
          <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
          </svg>
        </span>
        <div>
          <p class="text-sm font-semibold text-ink">{item.title}</p>
          <p class="mt-0.5 text-xs leading-5 text-cocoa">{item.detail}</p>
        </div>
      </div>
    ))}
  </div>
</section>
